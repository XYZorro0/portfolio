# Portfolio chatbot backend configuration.
# Copy to .env and fill in CHATBOT_API_KEY. Every value below shows its default.

# --- Server ---
# Bind address. Keep 127.0.0.1 so only cloudflared (same machine) can reach it.
HOST=127.0.0.1
PORT=3001

# Shared key the widget sends as X-API-Key. Generate one with:
#   node -e "console.log(crypto.randomBytes(24).toString('base64url'))"
# It ships inside the public widget JS — treat it as abuse friction, not a secret.
CHATBOT_API_KEY=

# Comma-separated origins allowed by CORS. Add http://127.0.0.1:8080 when
# testing the widget demo page locally.
ALLOWED_ORIGINS=https://niketgupta.com,https://www.niketgupta.com

# --- Ollama ---
OLLAMA_URL=http://127.0.0.1:11434
CHAT_MODEL=llama3.2:3b
EMBED_MODEL=nomic-embed-text
# How long Ollama keeps the model loaded in VRAM between requests.
KEEP_ALIVE=30m
OLLAMA_TIMEOUT_MS=120000

# --- Retrieval ---
# Number of chunks retrieved per question.
TOP_K=4
# Questions whose best chunk scores below this are answered with a canned
# off-topic redirect (no LLM call).
MIN_SIMILARITY=0.35
VECTOR_STORE=data/vector-store.json

# --- Abuse protection ---
# Per-IP fixed window rate limit.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
# Max requests waiting on the single-file GPU queue before returning 429.
MAX_PENDING=8
MAX_QUESTION_LENGTH=500
